# Streamlit Secrets Configuration
# 
# This file is used by Streamlit Cloud to provide API keys securely.
# NEVER commit this file to GitHub!
# 
# Instead, paste this into Streamlit Cloud Settings → Secrets panel:
# 1. Deploy your app on Streamlit Cloud
# 2. Go to your app dashboard
# 3. Click Settings (top-right menu)
# 4. Select "Secrets"
# 5. Paste the content below (without comments)
# 6. Click "Save"

GROQ_API_KEY = "gsk_your_groq_api_key_here"
PINECONE_API_KEY = "pcn_your_pinecone_api_key_here"
PINECONE_INDEX = "home-printer-docs"
HUGGINGFACE_API_KEY = "hf_your_huggingface_token_here"
DEBUG_MODE = false

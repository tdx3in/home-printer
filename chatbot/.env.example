# Chatbot Environment Variables
# Copy this file to .env and fill in your API keys

# Groq API Key - Get from console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Pinecone API Key - Get from app.pinecone.io
PINECONE_API_KEY=pcn_your_pinecone_api_key_here

# Pinecone Index Name
PINECONE_INDEX=home-printer-docs

# Hugging Face API Key - Get from huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# Optional: Enable debug mode to see additional logging
DEBUG_MODE=false
